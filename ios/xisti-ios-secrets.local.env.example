# Copy to xisti-ios-secrets.local.env (never commit) and fill from GitHub → Settings → Secrets.
# Same names as repository secrets in devSixti/xisti-mobile.

export APPLE_TEAM_ID=
export APP_STORE_CONNECT_API_KEY_ID=
export APP_STORE_CONNECT_ISSUER_ID=
# Paste full .p8 contents (including BEGIN/END lines) or use APP_STORE_CONNECT_API_KEY_P8=
export APP_STORE_CONNECT_API_KEY=
export MATCH_PASSWORD=
export MATCH_GIT_URL=https://github.com/YOUR_ORG/xisti-match-certs.git
# Plain ghp_… or base64(user:token)
export MATCH_GIT_BASIC_AUTHORIZATION=
# Optional App Store Connect numeric app id
# export APP_STORE_CONNECT_APP_ID=

export DART_DEFINES="--dart-define=API_DOMAIN=https://admin.xistiapp.com"
