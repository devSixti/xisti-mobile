# frozen_string_literal: true

require "base64"
require "fileutils"

default_platform(:ios)

platform :ios do
  BUNDLE_ID = "com.app.xisti"

  desc "Sync App Store signing via Match (bootstraps certs repo on first run)"
  lane :sync_signing do
    begin
      match(
        type: "appstore",
        app_identifier: BUNDLE_ID,
        readonly: true,
        api_key: asc_api_key,
        git_url: ENV.fetch("MATCH_GIT_URL"),
        git_basic_authorization: match_git_auth,
        verbose: true
      )
    rescue StandardError => e
      UI.important("Match readonly failed (#{e.message}); bootstrapping certificates…")
      match(
        type: "appstore",
        app_identifier: BUNDLE_ID,
        readonly: false,
        api_key: asc_api_key,
        git_url: ENV.fetch("MATCH_GIT_URL"),
        git_basic_authorization: match_git_auth,
        verbose: true
      )
    end

    mapping = Actions.lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
    profile_name = mapping[BUNDLE_ID]
    UI.user_error!("No provisioning profile from Match for #{BUNDLE_ID}") if profile_name.to_s.empty?

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      bundle_identifier: BUNDLE_ID,
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution",
      targets: ["Runner"]
    )

    profile_name
  end

  desc "Build release IPA with Flutter"
  lane :build_flutter_ipa do
    profile_name = sync_signing

    dart_defines = ENV.fetch("DART_DEFINES", "").strip
    flutter_args = ["flutter", "build", "ipa", "--release", "--export-method", "app-store"]
    flutter_args.concat(dart_defines.split) unless dart_defines.empty?

    Dir.chdir("..") do
      sh("flutter", "pub", "get")
      sh("flutter", "precache", "--ios")
    end

    # Resolve pods once here (same cwd as CI). Flutter build should skip or finish quickly.
    ENV["COCOAPODS_DISABLE_STATS"] = "true"
    sh("bundle", "exec", "pod", "install", "--verbose")

    Dir.chdir("..") do
      sh(*flutter_args)
    end

    ipa = Dir[File.expand_path("../build/ios/ipa/*.ipa", __dir__)].first
    unless ipa
      archive = File.expand_path("../build/ios/archive/Runner.xcarchive", __dir__)
      if File.directory?(archive)
        UI.important("flutter build ipa did not produce IPA; exporting archive with xcodebuild…")
        export_dir = File.expand_path("../build/ios/ipa", __dir__)
        FileUtils.mkdir_p(export_dir)
        export_plist = File.join(__dir__, "ExportOptions.plist")
        unless File.exist?(export_plist)
          File.write(
            export_plist,
            <<~PLIST
              <?xml version="1.0" encoding="UTF-8"?>
              <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
              <plist version="1.0"><dict>
                <key>method</key><string>app-store</string>
                <key>signingStyle</key><string>manual</string>
                <key>teamID</key><string>#{ENV.fetch("APPLE_TEAM_ID")}</string>
                <key>provisioningProfiles</key><dict>
                  <key>#{BUNDLE_ID}</key><string>#{profile_name}</string>
                </dict>
                <key>uploadSymbols</key><true/>
              </dict></plist>
            PLIST
          )
        end
        sh(
          "xcodebuild", "-exportArchive",
          "-archivePath", archive,
          "-exportPath", export_dir,
          "-exportOptionsPlist", export_plist,
          "-allowProvisioningUpdates"
        )
        ipa = Dir[File.join(export_dir, "*.ipa")].first
      end
    end
    UI.user_error!("IPA not found under build/ios/ipa") unless ipa

    ipa
  end

  desc "Build signed IPA and upload to App Store Connect (TestFlight → App Store)"
  lane :deploy_app_store do
    ipa_path = build_flutter_ipa

    upload_params = {
      api_key: asc_api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    }
    upload_params[:apple_id] = ENV["APP_STORE_CONNECT_APP_ID"] if ENV["APP_STORE_CONNECT_APP_ID"]

    upload_to_testflight(**upload_params)
  end

  desc "Mac deploy: manual signing + TestFlight (skips Match for local builder)"
  lane :mac_deploy_testflight do
    profile_name = "com.app.xisti AppStore"
    ios_root = File.expand_path("..", __dir__)
    repo_root = File.expand_path("../..", __dir__)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: File.join(ios_root, "Runner.xcodeproj"),
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      bundle_identifier: BUNDLE_ID,
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution",
      targets: ["Runner"]
    )

    dart_defines = ENV.fetch("DART_DEFINES", "").strip
    flutter_args = ["flutter", "build", "ipa", "--release", "--export-method", "app-store"]
    flutter_args.concat(dart_defines.split) unless dart_defines.empty?

    Dir.chdir(repo_root) { sh("flutter", "pub", "get") }
    Dir.chdir(ios_root) do
      ENV["COCOAPODS_DISABLE_STATS"] = "true"
      sh("bundle", "exec", "pod", "install")
    end
    Dir.chdir(repo_root) { sh(*flutter_args) }

    ipa = Dir[File.join(repo_root, "build/ios/ipa/*.ipa")].first
    unless ipa
      archive = File.join(repo_root, "build/ios/archive/Runner.xcarchive")
      if File.directory?(archive)
        export_dir = File.join(repo_root, "build/ios/ipa")
        FileUtils.mkdir_p(export_dir)
        export_plist = File.join(__dir__, "ExportOptions.plist")
        File.write(
          export_plist,
          <<~PLIST
            <?xml version="1.0" encoding="UTF-8"?>
            <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
            <plist version="1.0"><dict>
              <key>method</key><string>app-store</string>
              <key>signingStyle</key><string>manual</string>
              <key>teamID</key><string>#{ENV.fetch("APPLE_TEAM_ID")}</string>
              <key>provisioningProfiles</key><dict>
                <key>#{BUNDLE_ID}</key><string>#{profile_name}</string>
              </dict>
              <key>uploadSymbols</key><true/>
            </dict></plist>
          PLIST
        )
        sh(
          "xcodebuild", "-exportArchive",
          "-archivePath", archive,
          "-exportPath", export_dir,
          "-exportOptionsPlist", export_plist
        )
        ipa = Dir[File.join(export_dir, "*.ipa")].first
      end
    end
    UI.user_error!("IPA not found under build/ios/ipa") unless ipa

    upload_to_testflight(
      api_key: asc_api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Upload an existing IPA to TestFlight (no rebuild)"
  lane :upload_existing_ipa do
    repo_root = File.expand_path("../..", __dir__)
    ipa = ENV["IPA_PATH"] || Dir[File.join(repo_root, "build/ios/ipa/*.ipa")].max_by { |f| File.mtime(f) }
    UI.user_error!("IPA not found") unless ipa && File.file?(ipa)

    upload_to_testflight(
      api_key: asc_api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end

def asc_api_key
  key_content = ENV["APP_STORE_CONNECT_API_KEY"] || ENV["APP_STORE_CONNECT_API_KEY_P8"]
  if key_content.to_s.strip.empty?
    key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"].to_s.strip
    key_content = File.read(key_path) if key_path != "" && File.file?(key_path)
  end
  UI.user_error!("Missing APP_STORE_CONNECT_API_KEY, APP_STORE_CONNECT_API_KEY_P8, or APP_STORE_CONNECT_API_KEY_PATH") if key_content.to_s.strip.empty?

  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    key_content: key_content,
    is_key_content_base64: false
  )
end

def match_git_auth
  raw = ENV.fetch("MATCH_GIT_BASIC_AUTHORIZATION").strip
  return raw if raw.match?(/\A[A-Za-z0-9+\/]+=*\z/) && !raw.include?(":")

  Base64.strict_encode64(raw)
end
