git_url(ENV.fetch("MATCH_GIT_URL"))
storage_mode("git")
type("appstore")
app_identifier(["com.app.xisti"])

# Auth via App Store Connect API key (no Apple ID password in CI).
api_key(
  key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
  issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
  key_content: ENV["APP_STORE_CONNECT_API_KEY"] || ENV.fetch("APP_STORE_CONNECT_API_KEY_P8"),
  duration: 1200,
  in_house: false
)
